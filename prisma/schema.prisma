generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  preferences  Json?
  workspaces   Workspace[]
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt
}

model Workspace {
  id         String   @id @default(uuid())
  name       String
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  notes      Note[]
  tasks      Task[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
}

model Note {
  id           String          @id @default(uuid())
  workspace_id String
  workspace    Workspace       @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  title        String
  content      Json            // Lưu trữ Block-based dạng JSON
  tags         String[]
  tasks        NoteTaskLink[]
  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt

  @@index([workspace_id])
  @@index([updated_at]) // Phục vụ cho Offline Sync
}

model Task {
  id             String          @id @default(uuid())
  workspace_id   String
  workspace      Workspace       @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  title          String
  description    String?
  due_date       DateTime?
  priority       Int             @default(4) // 1: Khẩn cấp -> 4: Không quan trọng
  status         String          @default("todo") // todo, in_progress, done
  parent_task_id String?         // Self-relation cho Sub-tasks
  parent_task    Task?           @relation("SubTasks", fields: [parent_task_id], references: [id])
  sub_tasks      Task[]          @relation("SubTasks")
  notes          NoteTaskLink[]
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt

  @@index([workspace_id])
  @@index([due_date])
  @@index([updated_at]) // Phục vụ cho Offline Sync
}

model NoteTaskLink {
  note_id String
  task_id String
  note    Note   @relation(fields: [note_id], references: [id], onDelete: Cascade)
  task    Task   @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@id([note_id, task_id]) // Junction table
}
